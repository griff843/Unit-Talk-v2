{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unit-talk.internal/schemas/autonomy/autonomy-policy-v1.json",
  "title": "Autonomy policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mode", "owner_halt", "ceilings"],
  "properties": {
    "schema_version": { "const": 1 },
    "mode": {
      "enum": ["halted", "shadow", "t3-live", "t2-t3-live"]
    },
    "owner_halt": { "type": "boolean" },
    "owner_halt_reason": { "type": ["string", "null"] },
    "ceilings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_cycles",
        "max_duration_ms",
        "max_retries_per_candidate",
        "max_token_budget",
        "max_cost_micros"
      ],
      "properties": {
        "max_cycles": { "type": "integer", "minimum": 1 },
        "max_duration_ms": { "type": "integer", "minimum": 1 },
        "max_retries_per_candidate": { "type": "integer", "minimum": 0 },
        "max_token_budget": { "type": "integer", "minimum": 1 },
        "max_cost_micros": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
