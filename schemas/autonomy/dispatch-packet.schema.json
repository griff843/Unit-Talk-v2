{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unit-talk.internal/schemas/autonomy/dispatch-packet-v1.json",
  "title": "Immutable autonomy dispatch packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "run_id",
    "decision_id",
    "candidate",
    "created_at",
    "content_sha256"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "packet_id": { "type": "string", "pattern": "^packet_[0-9a-f]{64}$" },
    "run_id": { "type": "string", "minLength": 1 },
    "decision_id": { "type": "string", "pattern": "^decision_[0-9a-f]{64}$" },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue_id",
        "tier",
        "branch",
        "base_branch",
        "executor",
        "file_scope"
      ],
      "properties": {
        "issue_id": { "type": "string", "pattern": "^UTV2-[0-9]+$" },
        "tier": { "enum": ["T1", "T2", "T3"] },
        "branch": { "type": "string", "minLength": 1 },
        "base_branch": { "type": "string", "minLength": 1 },
        "executor": { "enum": ["claude", "codex-cli", "codex-cloud"] },
        "file_scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "content_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
