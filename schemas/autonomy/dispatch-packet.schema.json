{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unit-talk.dev/schemas/autonomy/dispatch-packet-v1.schema.json",
  "title": "Immutable autonomy dispatch packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "issue_id",
    "tier",
    "executor",
    "mode_at_dispatch",
    "generated_at",
    "expires_at",
    "file_scope_lock",
    "sensitive_path_check",
    "dispatch_reason",
    "idempotency_key",
    "kill_switch_check",
    "dry_run",
    "content_sha256"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "packet_id": { "type": "string", "pattern": "^packet_[a-f0-9]{64}$" },
    "issue_id": { "type": "string", "pattern": "^UTV2-[0-9]+$" },
    "tier": { "enum": ["T2", "T3"] },
    "executor": { "enum": ["claude", "codex-cli", "codex-cloud"] },
    "mode_at_dispatch": { "enum": ["shadow", "t3_live", "t2t3_live"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "file_scope_lock": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "sensitive_path_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "checked_against", "checked_at", "matched_paths"],
      "properties": {
        "passed": { "const": true },
        "checked_against": {
          "const": "docs/05_operations/DELEGATION_POLICY.md#sensitive-path-matrix"
        },
        "checked_at": { "type": "string", "format": "date-time" },
        "matched_paths": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 0
        }
      }
    },
    "dispatch_reason": { "type": "string", "minLength": 1 },
    "idempotency_key": {
      "type": "string",
      "pattern": "^UTV2-[0-9]+:lane-start:[A-Za-z0-9._-]+$"
    },
    "kill_switch_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checked_at", "halted"],
      "properties": {
        "checked_at": { "type": "string", "format": "date-time" },
        "halted": { "const": false }
      }
    },
    "dry_run": { "type": "boolean" },
    "content_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "concurrency_snapshot_ref": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "mode_at_dispatch": { "const": "shadow" } } },
      "then": { "properties": { "dry_run": { "const": true } } }
    }
  ]
}
