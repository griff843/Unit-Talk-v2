{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unit-talk.dev/schemas/autonomy/execution-record-v1.schema.json",
  "title": "Durable autonomy cycle execution record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cycle_id",
    "mode",
    "input_hash",
    "created_at",
    "updated_at",
    "transitions"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "cycle_id": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["halted", "shadow", "t3_live", "t2t3_live"] },
    "input_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sequence", "from", "to", "at"],
        "properties": {
          "sequence": { "type": "integer", "minimum": 1 },
          "from": { "$ref": "#/$defs/cycle_state" },
          "to": { "$ref": "#/$defs/cycle_state" },
          "at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "decision": { "type": "object" },
    "packet_id": { "type": "string" },
    "outcome": { "type": "object" }
  },
  "$defs": {
    "cycle_state": {
      "enum": [
        "idle",
        "waking",
        "gating",
        "selecting",
        "dispatching",
        "shadow_evaluating",
        "reporting",
        "cooling_down"
      ]
    }
  }
}
