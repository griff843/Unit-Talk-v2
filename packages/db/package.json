{
  "name": "@unit-talk/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "dist/index.js",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item -Recurse -Force dist }\"",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "types:generate": "supabase gen types typescript --local --schema public > src/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.56.0",
    "@unit-talk/config": "workspace:*",
    "@unit-talk/contracts": "workspace:*"
  }
}
