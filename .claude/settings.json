{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/bash-safety-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "echo '[pre-push] Running pnpm verify before push...' && pnpm verify && echo '[pre-push] verify passed.' || { echo '[pre-push] BLOCKED: pnpm verify failed.'; exit 2; }",
            "timeout": 120,
            "statusMessage": "Running pnpm verify before push..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "bash .claude/hooks/commit-msg-linear-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/artifact-drift-check.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/suggest-test-group.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-summary.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "untracked=$(git -C \"$(git rev-parse --show-toplevel 2>/dev/null)\" ls-files --others --exclude-standard -- 'scripts/' 'apps/*/src/scripts/' 'packages/*/src/scripts/' 2>/dev/null); if [ -n \"$untracked\" ]; then echo '{\"systemMessage\": \"WARNING: Untracked files in scripts/ at session end — commit or delete before closing:\\n'\"$untracked\"'\"}'; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/linear-sync-reminder.sh"
          }
        ]
      }
    ]
  }
}
