{
  "name": "@unit-talk/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item -Recurse -Force dist }\"",
    "dev": "tsx src/index.ts",
    "grading:cron": "tsx src/grading-cron.ts",
    "runs:failures": "tsx src/scripts/query-runs.ts --failures",
    "runs:recent": "tsx src/scripts/query-runs.ts --recent",
    "runs:summary": "tsx src/scripts/query-runs.ts --summary",
    "test:db": "tsx --test src/database-smoke.test.ts",
    "test": "tsx --test src/submission-service.test.ts src/server.test.ts src/server.http.test.ts src/http-integration.test.ts src/grading-cron.test.ts src/recap-service.test.ts src/alert-agent-service.test.ts src/alert-agent.test.ts src/hedge-detection-service.test.ts src/hedge-notification-service.test.ts src/shadow-model-summary-service.test.ts src/market-universe-materializer.test.ts src/board-scan-service.test.ts",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@unit-talk/alert-runtime": "workspace:*",
    "@unit-talk/config": "workspace:*",
    "@unit-talk/contracts": "workspace:*",
    "@unit-talk/db": "workspace:*",
    "@unit-talk/domain": "workspace:*",
    "@unit-talk/events": "workspace:*",
    "@unit-talk/intelligence": "workspace:*",
    "@unit-talk/observability": "workspace:*",
    "@unit-talk/verification": "workspace:*",
    "jose": "^6.2.2"
  }
}
