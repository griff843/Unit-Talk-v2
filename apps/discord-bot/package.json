{
  "name": "@unit-talk/discord-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item -Recurse -Force dist }\"",
    "dev": "tsx src/index.ts",
    "deploy-commands": "tsx scripts/deploy-commands.ts",
    "test": "tsx --test src/discord-bot-foundation.test.ts",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@unit-talk/config": "workspace:*",
    "@unit-talk/contracts": "workspace:*",
    "@unit-talk/events": "workspace:*",
    "@unit-talk/observability": "workspace:*",
    "discord.js": "^14.22.1"
  }
}
