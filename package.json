{
  "name": "@unit-talk/v2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "description": "Unit Talk 2.0 greenfield monorepo",
  "scripts": {
    "backfill:sgo-history": "tsx scripts/backfill-sgo-history.ts",
    "build": "pnpm exec tsc -b tsconfig.json",
    "bootstrap:canonical-reference": "tsx scripts/run-canonical-reference-bootstrap.ts",
    "deploy:check": "tsx scripts/deploy-check.ts",
    "clean": "pnpm -r --if-present run clean",
    "dev": "pnpm --filter @unit-talk/api dev",
    "env:check": "node scripts/validate-env.mjs",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "github:checks": "tsx scripts/github-workflow.ts checks",
    "github:current": "tsx scripts/github-workflow.ts current",
    "github:summary": "tsx scripts/github-workflow.ts summary",
    "linear:close": "tsx scripts/linear-workflow.ts close",
    "linear:comment": "tsx scripts/linear-workflow.ts comment",
    "linear:issues": "tsx scripts/linear-workflow.ts issues",
    "linear:work": "tsx scripts/linear-workflow.ts work",
    "linear:update": "tsx scripts/linear-workflow.ts update",
    "lint": "eslint .",
    "ops:brief": "tsx scripts/ops-brief.ts",
    "pipeline:health": "tsx scripts/pipeline-health.ts",
    "proof:t1": "tsx scripts/t1-proof-bundle.ts",
    "queue:claim": "node scripts/claim-issue.mjs",
    "queue:status": "node scripts/queue-status.mjs",
    "queue:submit": "node scripts/submit-issue.mjs",
    "report:canonical-reference-bootstrap": "tsx scripts/report-canonical-reference-bootstrap.ts",
    "supabase:types": "node scripts/generate-types.mjs",
    "test:db": "tsx --test apps/api/src/database-smoke.test.ts",
    "test:apps-api-core": "tsx --test apps/api/src/domain-analysis-service.test.ts && tsx --test apps/api/src/promotion-edge-integration.test.ts && tsx --test apps/api/src/submission-service.test.ts && tsx --test apps/api/src/settlement-service.test.ts && tsx --test apps/api/src/golden-regression.test.ts && tsx --test apps/api/src/clv-service.test.ts && tsx --test apps/api/src/grading-service.test.ts && tsx --test apps/api/src/model-registry.test.ts && tsx --test apps/api/src/replayable-scoring.test.ts",
    "test:apps-api-agent": "tsx --test apps/api/src/grading-cron.test.ts && tsx --test apps/api/src/recap-service.test.ts && tsx --test apps/api/src/alert-agent-service.test.ts && tsx --test apps/api/src/alert-agent.test.ts && tsx --test apps/api/src/hedge-detection-service.test.ts && tsx --test apps/api/src/hedge-notification-service.test.ts && tsx --test apps/api/src/player-enrichment-service.test.ts && tsx --test apps/api/src/server.test.ts && tsx --test apps/api/src/http-integration.test.ts",
    "test:apps-rest": "tsx --test apps/ingestor/src/ingestor.test.ts && tsx --test apps/ingestor/src/circuit-breaker.test.ts && tsx --test apps/worker/src/worker-runtime.test.ts && tsx --test apps/operator-web/src/server.test.ts && tsx --test apps/discord-bot/src/discord-bot-foundation.test.ts && tsx --test packages/db/src/member-tier-repository.test.ts && tsx --test packages/db/src/canonical-reference-schema.test.ts && tsx --test packages/db/src/canonical-market-taxonomy.test.ts && tsx --test packages/db/src/canonical-reference-bootstrap.test.ts",
    "test:smart-form": "tsx --test apps/smart-form/test/form-schema.test.ts apps/smart-form/test/form-utils.test.ts apps/smart-form/test/api-client.test.ts",
    "test:apps": "pnpm test:apps-api-core && pnpm test:apps-api-agent && pnpm test:apps-rest && pnpm test:smart-form",
    "test:verification": "tsx --test packages/verification/src/scenarios/registry.test.ts packages/verification/src/run-history/run-store.test.ts packages/verification/src/run-history/query.test.ts packages/verification/src/archive/registry.test.ts",
    "test:domain-probability": "tsx --test packages/domain/src/probability/devig.test.ts packages/domain/src/probability/probability-layer.test.ts packages/domain/src/probability/calibration.test.ts packages/domain/src/outcomes/outcome-resolver.test.ts packages/domain/src/outcomes/loss-attribution.test.ts packages/domain/src/outcomes/settlement-downstream.test.ts",
    "test:domain-features": "tsx --test packages/domain/src/features/player-form.test.ts packages/domain/src/features/game-context.test.ts packages/domain/src/features/opportunity.test.ts packages/domain/src/features/efficiency.test.ts packages/domain/src/models/model-blend.test.ts packages/domain/src/models/clv-forecast.test.ts packages/domain/src/models/stat-distribution.test.ts packages/domain/src/models/stat-market-blend.test.ts packages/domain/src/models/sharp-consensus.test.ts",
    "test:domain-signals": "tsx --test packages/domain/src/signals/market-signals.test.ts packages/domain/src/signals/book-dispersion.test.ts packages/domain/src/signals/signal-quality.test.ts packages/domain/src/bands/bands.test.ts packages/domain/src/probability/calibration.test.ts packages/domain/src/scoring/scoring-weights.test.ts",
    "test:domain-hedge": "tsx --test packages/domain/src/hedge-detection.test.ts && tsx --test packages/domain/src/multi-book-consensus.test.ts && tsx --test packages/domain/src/clv-weight-tuner.test.ts && tsx --test packages/domain/src/member-lifecycle.test.ts",
    "test:domain-shadow": "tsx --test packages/domain/src/shadow-mode.test.ts && tsx --test packages/domain/src/promotion-conviction.test.ts",
    "test:domain-analytics": "tsx --test packages/domain/src/outcomes/outcomes.test.ts packages/domain/src/market/market-reaction.test.ts packages/domain/src/evaluation/evaluation.test.ts packages/domain/src/edge-validation/edge-validation.test.ts packages/domain/src/rollups/rollups.test.ts packages/domain/src/system-health/system-health.test.ts packages/domain/src/risk/risk.test.ts packages/domain/src/strategy/strategy.test.ts packages/domain/src/market-key.test.ts",
    "test": "pnpm test:apps && pnpm test:verification && pnpm test:domain-probability && pnpm test:domain-features && pnpm test:domain-signals && pnpm test:domain-hedge && pnpm test:domain-shadow && pnpm test:domain-analytics",
    "type-check": "pnpm exec tsc -b tsconfig.json",
    "verify:pick": "tsx scripts/verify-pick.ts",
    "verify:commands": "pnpm --filter @unit-talk/discord-bot command-manifest:check && node scripts/check-migration-versions.mjs",
    "verify": "pnpm env:check && pnpm lint && pnpm type-check && pnpm build && pnpm test && pnpm --filter @unit-talk/smart-form verify && pnpm verify:commands"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^24.5.2",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.29.1"
  },
  "dependencies": {},
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    },
    "peerDependencyRules": {
      "ignoreMissing": ["@playwright/test"]
    }
  }
}
