# Runtime env file for containerized Unit Talk V2 services.
# Copy to .env.container and fill in secrets. Never commit .env.container.

# ── Shared (all services) ────────────────────────────────────────────────────
UNIT_TALK_APP_ENV=production
UNIT_TALK_API_RUNTIME_MODE=fail_closed
UNIT_TALK_IMAGE_TAG=
UNIT_TALK_GIT_SHA=
UNIT_TALK_BUILD_TIMESTAMP=
UNIT_TALK_DEPLOYMENT_ID=
UNIT_TALK_SCORER_RUNTIME_VERSION=candidate-scoring-ownership-v1
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── API ──────────────────────────────────────────────────────────────────────
PORT=4000
UNIT_TALK_API_KEY_SUBMITTER=
UNIT_TALK_API_KEY_SETTLER=
UNIT_TALK_API_KEY_POSTER=
UNIT_TALK_API_KEY_WORKER=
UNIT_TALK_API_KEY_OPERATOR=
UNIT_TALK_DISCORD_WEBHOOK_URL=
UNIT_TALK_DISCORD_TARGET_MAP=
UNIT_TALK_OPS_ALERT_WEBHOOK_URL=
UNIT_TALK_INGESTOR_OFFER_STALE_MINUTES=30
OPENAI_API_KEY=

# ── Worker ───────────────────────────────────────────────────────────────────
UNIT_TALK_WORKER_ADAPTER=discord
UNIT_TALK_WORKER_ID=worker-1
UNIT_TALK_WORKER_POLL_MS=5000
UNIT_TALK_DISTRIBUTION_TARGETS=
UNIT_TALK_WORKER_DRY_RUN=false
UNIT_TALK_WORKER_AUTORUN=true

# ── Ingestor ─────────────────────────────────────────────────────────────────
SGO_API_KEY=
SGO_API_KEY_FALLBACK=
ODDS_API_KEY=
UNIT_TALK_API_URL=http://api:4000
UNIT_TALK_INGESTOR_SCHEDULING_ENABLED=false
UNIT_TALK_INGESTOR_PEAK_POLL_MS=30000
UNIT_TALK_INGESTOR_OFFPEAK_POLL_MS=300000
UNIT_TALK_INGESTOR_PEAK_START_HOUR_ET=12
UNIT_TALK_INGESTOR_PEAK_END_HOUR_ET=24
UNIT_TALK_INGESTOR_PINNACLE_ONLY_PEAK=false
UNIT_TALK_INGESTOR_AUTORUN=true

# ── Discord Bot ──────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_CAPPER_ROLE_ID=
DISCORD_OPERATOR_ROLE_ID=
DISCORD_VIP_ROLE_ID=
DISCORD_VIP_PLUS_ROLE_ID=
DISCORD_TRIAL_ROLE_ID=
DISCORD_CAPPER_CHANNEL_ID=
DISCORD_ANNOUNCEMENT_CHANNEL_ID=
CANARY_CHANNEL_ID=

# ── Optional: structured log sink ────────────────────────────────────────────
# LOKI_URL=http://loki:3100/loki/api/v1/push
