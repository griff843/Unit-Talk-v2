{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unit-talk.dev/schemas/required_ci_checks_v1.schema.json",
  "title": "Required CI Checks Inventory V1",
  "type": "object",
  "required": ["schema_version", "checks"],
  "properties": {
    "schema_version": { "const": 1 },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "workflow": { "type": "string" },
          "job": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
