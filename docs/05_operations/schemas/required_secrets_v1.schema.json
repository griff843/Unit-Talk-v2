{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unit-talk.dev/schemas/required_secrets_v1.schema.json",
  "title": "Required Secrets Inventory V1",
  "type": "object",
  "required": ["schema_version", "secrets"],
  "properties": {
    "schema_version": { "const": 1 },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "scope": { "type": "string" },
          "used_by": { "type": "array", "items": { "type": "string" } },
          "environment": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
