{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unit-talk.dev/schemas/ci_doctor_result_v1.schema.json",
  "title": "CI Doctor Result V1",
  "type": "object",
  "required": [
    "schema_version",
    "run_at",
    "mode",
    "repo",
    "scope",
    "verdict",
    "exit_code",
    "checks",
    "failures",
    "infra_errors",
    "skips",
    "summary"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_at": { "type": "string", "format": "date-time" },
    "mode": { "enum": ["local", "scheduled"] },
    "repo": { "type": "string" },
    "scope": { "enum": ["workflows", "secrets", "protection", "preview", "required-checks", "artifacts", "all"] },
    "verdict": { "enum": ["PASS", "FAIL", "INFRA"] },
    "exit_code": { "enum": [0, 1, 3] },
    "checks": { "type": "array" },
    "failures": { "type": "array", "items": { "type": "string" } },
    "infra_errors": { "type": "array", "items": { "type": "string" } },
    "skips": { "type": "array", "items": { "type": "string" } },
    "summary": { "type": "object" }
  },
  "additionalProperties": true
}
