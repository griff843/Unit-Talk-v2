{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unit-talk.dev/schemas/truth_check_result_v1.schema.json",
  "title": "Truth Check Result V1",
  "type": "object",
  "required": [
    "schema_version",
    "issue_id",
    "tier",
    "verdict",
    "exit_code",
    "merge_sha",
    "pr_url",
    "checked_at",
    "checks",
    "failures",
    "reopen_reasons",
    "manifest_path"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "issue_id": { "type": "string", "pattern": "^UTV2-[0-9]+$" },
    "tier": { "enum": ["T1", "T2", "T3"] },
    "verdict": {
      "enum": ["pass", "fail", "ineligible", "reopen", "infra_error"]
    },
    "exit_code": { "enum": [0, 1, 2, 3, 4] },
    "merge_sha": { "type": ["string", "null"] },
    "pr_url": { "type": ["string", "null"] },
    "checked_at": { "type": "string", "format": "date-time" },
    "checks": { "type": "array" },
    "failures": { "type": "array", "items": { "type": "string" } },
    "reopen_reasons": { "type": "array", "items": { "type": "string" } },
    "manifest_path": { "type": "string" }
  },
  "additionalProperties": true
}
