# Unit Talk V2 shared environment template

NODE_ENV=development
UNIT_TALK_APP_ENV=local
UNIT_TALK_ACTIVE_WORKSPACE=C:\Dev\Unit-Talk-v2-main
UNIT_TALK_LEGACY_WORKSPACE=C:\dev\unit-talk-production

LINEAR_API_TOKEN=
LINEAR_TEAM_ID=
LINEAR_TEAM_KEY=UTV2
LINEAR_TEAM_NAME=unit-talk-v2
# Fibery is canonical governance truth. Configure this to a Fibery automation webhook
# that appends the supplied ops:update-record note to the referenced entity.
FIBERY_UPDATE_WEBHOOK_URL=
FIBERY_UPDATE_WEBHOOK_TOKEN=
FIBERY_API_URL=
FIBERY_API_TOKEN=
FIBERY_SYNC_DRY_RUN=false
NOTION_WORKSPACE_NAME=unit-talk-v2
SLACK_WORKSPACE_NAME=unit-talk-v2

SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
# API Authentication — Bearer token keys per role (UTV2-215)
# Auth is bypassed when no keys are set AND UNIT_TALK_APP_ENV=local.
# In production (fail_closed), at least one key must be configured.
UNIT_TALK_API_KEY_OPERATOR=
UNIT_TALK_API_KEY_SUBMITTER=
UNIT_TALK_API_KEY_SETTLER=
UNIT_TALK_API_KEY_POSTER=
UNIT_TALK_API_KEY_WORKER=
UNIT_TALK_API_RUNTIME_MODE=fail_open
# HS256 secret for signing/verifying capper JWT tokens (UTV2-658).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UNIT_TALK_JWT_SECRET=

SGO_API_KEY=
SGO_API_KEY_FALLBACK=
UNIT_TALK_INGESTOR_LEAGUES=NBA,NFL,MLB,NHL
UNIT_TALK_INGESTOR_POLL_MS=300000
UNIT_TALK_INGESTOR_MAX_CYCLES=1
UNIT_TALK_INGESTOR_AUTORUN=false
UNIT_TALK_INGESTOR_SKIP_RESULTS=false
UNIT_TALK_INGESTOR_RESULTS_MAX_FETCH_MS=300000
UNIT_TALK_WORKER_ID=worker-dev
# Local/dev delivery is canary-only. Do not alias live symbolic lanes to the canary channel.
UNIT_TALK_DISTRIBUTION_TARGETS=discord:canary
# UNIT_TALK_ENABLED_TARGETS=best-bets,trader-insights  # comma-separated; omit to use defaults (exclusive-insights disabled)
UNIT_TALK_WORKER_ADAPTER=stub
# Local/dev example: {"discord:canary":"1296531122234327100"}
# Production live targets: {"discord:canary":"1296531122234327100","discord:best-bets":"1288613037539852329","discord:trader-insights":"1356613995175481405","discord:recaps":"1300411261854547968"}
# Deferred targets (do NOT include in production UNIT_TALK_DISCORD_TARGET_MAP — see DISTRIBUTION_TARGETS.md):
#   discord:exclusive-insights — deferred, governance-gated
#   discord:game-threads       — not implemented (thread routing not built)
#   discord:strategy-room      — not implemented (DM routing not built)
UNIT_TALK_DISCORD_TARGET_MAP=
UNIT_TALK_WORKER_POLL_MS=5000
UNIT_TALK_WORKER_MAX_CYCLES=1
UNIT_TALK_WORKER_DRY_RUN=true
UNIT_TALK_WORKER_AUTORUN=false
UNIT_TALK_WORKER_STALE_CLAIM_MS=300000
UNIT_TALK_WORKER_HEARTBEAT_MS=5000
UNIT_TALK_WORKER_WATCHDOG_MS=30000
UNIT_TALK_WORKER_CIRCUIT_BREAKER_THRESHOLD=5
UNIT_TALK_WORKER_CIRCUIT_BREAKER_COOLDOWN_MS=300000
WORKER_HEARTBEAT_INTERVAL_MS=30000
UNIT_TALK_SIMULATION_MODE=false
UNIT_TALK_SHADOW_MODE=
RECAP_DRY_RUN=false
# Alert agent runtime controls:
# ALERT_AGENT_ENABLED=false disables detection + notification entirely.
# ALERT_DRY_RUN=true keeps alerts in simulation mode: counts/logging only, no Discord post, no system-pick submit.
# SYSTEM_PICKS_ENABLED=true allows alert-worthy eligible alerts to submit to POST /api/submissions,
# but only when ALERT_DRY_RUN=false.
ALERT_AGENT_ENABLED=true
ALERT_DRY_RUN=true
ALERT_MIN_TIER=notable
ALERT_LOOKBACK_MINUTES=60
# Alert threshold overrides. Units:
# spread/total/prop = line points, ML = American juice points, velocity window = minutes.
ALERT_THRESHOLD_SPREAD_WATCH=0.5
ALERT_THRESHOLD_SPREAD_NOTABLE=2.0
ALERT_THRESHOLD_SPREAD_ALERT_WORTHY=3.5
ALERT_THRESHOLD_SPREAD_VELOCITY=0.5
ALERT_THRESHOLD_TOTAL_WATCH=0.5
ALERT_THRESHOLD_TOTAL_NOTABLE=1.5
ALERT_THRESHOLD_TOTAL_ALERT_WORTHY=3.0
ALERT_THRESHOLD_TOTAL_VELOCITY=0.5
ALERT_THRESHOLD_ML_WATCH=5
ALERT_THRESHOLD_ML_NOTABLE=10
ALERT_THRESHOLD_ML_ALERT_WORTHY=20
ALERT_THRESHOLD_ML_VELOCITY=10
ALERT_THRESHOLD_PROP_WATCH=0.25
ALERT_THRESHOLD_PROP_NOTABLE=0.5
ALERT_THRESHOLD_PROP_ALERT_WORTHY=1.5
ALERT_THRESHOLD_PROP_VELOCITY=0.25
ALERT_VELOCITY_WINDOW_MINUTES=15
ALERT_STEAM_MIN_BOOKS=3
ALERT_STEAM_WINDOW_MINUTES=10
SYSTEM_PICKS_ENABLED=false

# System pick scanner: auto-generates player prop picks from SGO opening lines.
# Requires UNIT_TALK_API_URL and UNIT_TALK_API_KEY_SUBMITTER to be set.
# SYSTEM_PICK_SCANNER_LOOKBACK_HOURS: how far back to scan (default: 24)
# SYSTEM_PICK_SCANNER_MAX_PICKS: max picks to submit per 5-min run (default: 100)
SYSTEM_PICK_SCANNER_ENABLED=false
SYSTEM_PICK_SCANNER_LOOKBACK_HOURS=24
SYSTEM_PICK_SCANNER_MAX_PICKS=100
# SYNDICATE_MACHINE_ENABLED: enables board-scan service candidate materialization (default: false)
SYNDICATE_MACHINE_ENABLED=false
# BOARD_PICK_WRITER_ENABLED: promotes syndicate_board entries to picks on 10-min scheduler (default: false, UTV2-749)
BOARD_PICK_WRITER_ENABLED=false

DISCORD_BOT_TOKEN=
# DISCORD_CLIENT_ID: the Application ID (not the bot user ID) for the app that owns DISCORD_BOT_TOKEN.
# Find it at: Discord Developer Portal → Applications → <your app> → General Information → Application ID.
# The first segment of the bot token (before the first dot) is base64(Application ID) — they must match.
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=1284478946171293736
# Tier-gated command role IDs (required for member tier resolution and onboarding)
DISCORD_CAPPER_ROLE_ID=
DISCORD_VIP_ROLE_ID=
DISCORD_VIP_PLUS_ROLE_ID=
DISCORD_TRIAL_ROLE_ID=
# Optional — if absent, /alerts-setup and other operator-gated commands block all users (sentinel behavior)
DISCORD_OPERATOR_ROLE_ID=
DISCORD_CAPPER_CHANNEL_ID=
UNIT_TALK_API_URL=
UNIT_TALK_INGESTOR_RUNTIME_MODE=fail_open
# Provider-offer freshness threshold for ingestor staleness alerts and operator health.
# Default: 30 minutes.
UNIT_TALK_INGESTOR_OFFER_STALE_MINUTES=30
# Provider-offer staging scaffold mode. Default: off.
# off = disabled, stage_only = write provider_offer_staging/provider_cycle_status only,
# stage_and_merge_verified = require fresh data plus explicit replay-proof status before bounded merge.
UNIT_TALK_PROVIDER_OFFER_STAGING_MODE=off
# Ingestion DB write policy for provider-offer staging/merge paths.
UNIT_TALK_INGESTOR_DB_STATEMENT_TIMEOUT_MS=15000
UNIT_TALK_INGESTOR_DB_LOCK_TIMEOUT_MS=5000
UNIT_TALK_INGESTOR_DB_MAX_BATCH_SIZE=500
UNIT_TALK_INGESTOR_DB_MERGE_CHUNK_SIZE=250
UNIT_TALK_INGESTOR_DB_RETRY_MAX_ATTEMPTS=2
UNIT_TALK_INGESTOR_DB_RETRY_BACKOFF_MS=1000
# Raw provider payload archive policy.
# fail_open = spool archive failures locally and keep freshness-critical writes moving
# fail_closed = block the cycle when archive capture cannot complete
UNIT_TALK_PROVIDER_PAYLOAD_ARCHIVE_MODE=fail_open
UNIT_TALK_PROVIDER_PAYLOAD_ARCHIVE_DIR=out/provider-payload-archive
# Discord webhook URL for ops staleness alerts. When set, grading-cron and ingestor post
# a message here when the gap since last run exceeds the configured threshold.
# Create at: Discord channel settings > Integrations > Webhooks
UNIT_TALK_OPS_ALERT_WEBHOOK_URL=
# Maximum request body size for all POST endpoints in apps/api. Default: 65536 (64 KB).
UNIT_TALK_API_MAX_BODY_BYTES=65536
DISCORD_ANNOUNCEMENT_CHANNEL_ID=
# Recap posts resolve via UNIT_TALK_DISCORD_TARGET_MAP using discord:recaps (1300411261854547968).

OPENAI_API_KEY=

# Trial auto-expiry: number of days after joining before a trial tier row is automatically
# deactivated by the background scheduler. Canonical value is 7.
TRIAL_DURATION_DAYS=7

# Scoring profile for promotion evaluation. Options: default, conservative
# Default: default
UNIT_TALK_SCORING_PROFILE=default

# Submission rate limiting (POST /api/submissions)
# Max submissions allowed per key (Discord user ID or IP) per minute. Default: 10.
UNIT_TALK_RATE_LIMIT_SUBMISSIONS_PER_MINUTE=10
# Advanced overrides: these take precedence over UNIT_TALK_RATE_LIMIT_SUBMISSIONS_PER_MINUTE when set.
# UNIT_TALK_API_SUBMISSION_RATE_LIMIT_MAX=10
# UNIT_TALK_API_SUBMISSION_RATE_LIMIT_WINDOW_MS=60000

COMMAND_CENTER_PORT=4300

# The Odds API — multi-book consensus + Pinnacle sharp line + historical odds
# Sign up: https://the-odds-api.com | Bookmakers: pinnacle, draftkings, fanduel, betmgm
ODDS_API_KEY=

# Centralized logging (Loki + Grafana)
# LOKI_URL=http://localhost:3100  # Enable to ship logs to Loki. Start with: docker compose -f docker-compose.logging.yml up -d

# Notion checkpoint sync (scripts/notion-sync.ts)
NOTION_API_KEY=
NOTION_DATABASE_ID=
