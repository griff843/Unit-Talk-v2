# Unit Talk V2 shared environment template

NODE_ENV=development
UNIT_TALK_APP_ENV=local
UNIT_TALK_ACTIVE_WORKSPACE=C:\dev\unit-talk-v2
UNIT_TALK_LEGACY_WORKSPACE=C:\dev\unit-talk-production

LINEAR_API_TOKEN=
LINEAR_TEAM_ID=
LINEAR_TEAM_KEY=UTV2
LINEAR_TEAM_NAME=unit-talk-v2
NOTION_WORKSPACE_NAME=unit-talk-v2
SLACK_WORKSPACE_NAME=unit-talk-v2

SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SGO_API_KEY=
UNIT_TALK_INGESTOR_LEAGUES=NBA,NFL,MLB,NHL
UNIT_TALK_INGESTOR_POLL_MS=300000
UNIT_TALK_INGESTOR_MAX_CYCLES=1
UNIT_TALK_INGESTOR_AUTORUN=false
UNIT_TALK_INGESTOR_SKIP_RESULTS=false
UNIT_TALK_WORKER_ID=worker-dev
UNIT_TALK_DISTRIBUTION_TARGETS=discord:canary
# UNIT_TALK_ENABLED_TARGETS=best-bets,trader-insights  # comma-separated; omit to use defaults (exclusive-insights disabled)
UNIT_TALK_WORKER_ADAPTER=stub
# Canonical approved target map â€” see docs/05_operations/discord_routing.md
# {"discord:canary":"1296531122234327100","discord:best-bets":"1288613037539852329","discord:exclusive-insights":"1288613114815840466","discord:game-threads":"1291234713213734912","discord:trader-insights":"1356613995175481405","discord:strategy-room":"1356624758485287105","discord:recaps":"1300411261854547968"}
UNIT_TALK_DISCORD_TARGET_MAP=
UNIT_TALK_WORKER_POLL_MS=5000
UNIT_TALK_WORKER_MAX_CYCLES=1
UNIT_TALK_WORKER_DRY_RUN=true
UNIT_TALK_WORKER_AUTORUN=false
UNIT_TALK_WORKER_CIRCUIT_BREAKER_THRESHOLD=5
UNIT_TALK_WORKER_CIRCUIT_BREAKER_COOLDOWN_MS=300000
RECAP_DRY_RUN=false

DISCORD_BOT_TOKEN=
# DISCORD_CLIENT_ID: the Application ID (not the bot user ID) for the app that owns DISCORD_BOT_TOKEN.
# Find it at: Discord Developer Portal → Applications → <your app> → General Information → Application ID.
# The first segment of the bot token (before the first dot) is base64(Application ID) — they must match.
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=1284478946171293736
# Tier-gated command role IDs (required for member tier resolution and onboarding)
DISCORD_CAPPER_ROLE_ID=
DISCORD_VIP_ROLE_ID=
DISCORD_VIP_PLUS_ROLE_ID=
DISCORD_TRIAL_ROLE_ID=
# Optional — if absent, /alerts-setup and other operator-gated commands block all users (sentinel behavior)
DISCORD_OPERATOR_ROLE_ID=
DISCORD_CAPPER_CHANNEL_ID=
UNIT_TALK_API_URL=
# Maximum request body size for all POST endpoints in apps/api. Default: 65536 (64 KB).
UNIT_TALK_API_MAX_BODY_BYTES=65536
DISCORD_ANNOUNCEMENT_CHANNEL_ID=
# Recap posts resolve via UNIT_TALK_DISCORD_TARGET_MAP using discord:recaps (1300411261854547968).

OPENAI_API_KEY=

# Trial auto-expiry: number of days after joining before a trial tier row is automatically
# deactivated by the background scheduler. Canonical value is 7.
TRIAL_DURATION_DAYS=7

# Scoring profile for promotion evaluation. Options: default, conservative
# Default: default
UNIT_TALK_SCORING_PROFILE=default

# Submission rate limiting (POST /api/submissions)
# Max submissions allowed per key (Discord user ID or IP) per minute. Default: 10.
UNIT_TALK_RATE_LIMIT_SUBMISSIONS_PER_MINUTE=10
# Advanced overrides: these take precedence over UNIT_TALK_RATE_LIMIT_SUBMISSIONS_PER_MINUTE when set.
# UNIT_TALK_API_SUBMISSION_RATE_LIMIT_MAX=10
# UNIT_TALK_API_SUBMISSION_RATE_LIMIT_WINDOW_MS=60000

COMMAND_CENTER_PORT=4300

# Centralized logging (Loki + Grafana)
# LOKI_URL=http://localhost:3100  # Enable to ship logs to Loki. Start with: docker compose -f docker-compose.logging.yml up -d

# Notion checkpoint sync (scripts/notion-sync.ts)
NOTION_API_KEY=
NOTION_DATABASE_ID=
